{
  "name": "ai-news-aggregator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI engineering news aggregator — Express backend (HN + ArXiv + best-effort blogs + optional Claude summaries) serving a React/Vite frontend.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch --use-system-ca server/index.js",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web install && npm --prefix web run build",
    "start": "node --use-system-ca server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^4.21.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
