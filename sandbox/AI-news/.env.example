# ===========================================================================
# AI News Aggregator — environment configuration
# Copy this file to ".env" and fill in values as needed.
# The site works fully WITHOUT any keys (summaries fall back to excerpts).
# ===========================================================================

# Optional. Anthropic API key for Claude-powered article summaries.
# If unset/empty: summaries are DISABLED and the API returns source excerpts
# as the summary. summariesEnabled will be false. The site still works.
ANTHROPIC_API_KEY=

# Optional. NewsAPI.org key. If set, NewsAPI is added as an extra source.
# If unset/empty: NewsAPI is simply skipped (not reported as a failure).
NEWSAPI_KEY=

# Backend HTTP port. Default 8787.
PORT=8787

# Cache time-to-live in minutes. Clamped to the 30-60 range. Default 45.
CACHE_TTL_MINUTES=45

# Max number of articles that receive an LLM summary per fetch cycle (cost
# control). Only relevant when ANTHROPIC_API_KEY is set. Default 30.
SUMMARIZE_LIMIT=30
